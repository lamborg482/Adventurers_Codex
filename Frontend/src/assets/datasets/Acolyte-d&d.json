matic":true,"material":false,"ritual":false,"concentration":false},"materials":{"value":"","consumed":false,"cost":0,"supply":0},"preparation":{"mode":"always","prepared":true},"scaling":{"mode":"cantrip","formula":"1d8"}},"ownership":{"default":0,"Zs7yJru4DCapi5DP":3,"18Fg0JMS7l4EDZs7":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"rY801jqj5iDaST66","name":"Тавматургия","type":"spell","img":"modules/laaru-dnd5-hw/assets/icons/spell/phb-thaumaturgy.webp","effects":[],"folder":null,"sort":0,"flags":{"srd5e":{"page":"","source":"PHB","hash":"thaumaturgy_phb","":"spell"},"betterRolls5e":{"critRange":{"type":"String","value":null},"critDamage":{"type":"String","value":""},"quickDesc":{"type":"Boolean","value":true,"altValue":true},"quickAttack":{"type":"Boolean","value":true,"altValue":true},"quickSave":{"type":"Boolean","value":true,"altValue":true},"quickDamage":{"type":"Array","value":[],"altValue":[],"context":[]},"quickVersatile":{"type":"Boolean","value":false,"altValue":false},"quickProperties":{"type":"Boolean","value":true,"altValue":true},"quickCharges":{"type":"Boolean","value":{"use":true,"resource":true},"altValue":{"use":true,"resource":true}},"quickTemplate":{"type":"Boolean","value":true,"altValue":true},"quickOther":{"type":"Boolean","value":true,"altValue":true,"context":""},"quickFlavor":{"type":"Boolean","value":true,"altValue":true},"quickPrompt":{"type":"Boolean","value":false,"altValue":false}},"core":{"sourceId":"Item.TfHTlYOXsZ38Eg0d"}},"system":{"description":{"value":"<div class=\"rd__b  rd__b--3\">\n<p>Вы творите маленькое чудо, знак сверхъестественной силы. Вы можете создать один из этих магических эффектов в пределах дистанции:</p>\n<ul class=\"rd__list\">\n<li class=\"rd__li \">Сделать свой голос втрое громче обычного на 1 минуту.</li>\n<li class=\"rd__li \">Заставить пламя трепетать, вспыхивать, тускнеть или менять цвет на 1 минуту.</li>\n<li class=\"rd__li \">Вызвать безвредную дрожь земли на 1 минуту.</li>\n<li class=\"rd__li \">Вызвать мгновенный звук, который исходит из выбраной вами точки в пределах дистанции, например рокот грома, крик ворона или звовещий шёпот.</li>\n<li class=\"rd__li \">Заставить незапертую дверь или окно мгновенно открыться или закрыться.</li>\n<li class=\"rd__li \">Изменить вид ваших глаз на 1 минуту.</li>\n</ul>\n<p>Если сотворить это заклинание несколько раз, можно поддерживать до трёх 1-минутных эффектов одновременно. Любой из таких эффектов вы можете прекратить, потратив действие.</p>\n</div>","chat":"","unidentified":""},"source":"PHB","activation":{"type":"action","cost":1,"condition":""},"duration":{"value":"1","units":"minute"},"cover":null,"target":{"value":0,"width":null,"units":"","type":""},"range":{"value":30,"long":null,"units":"ft"},"uses":{"value":0,"max":"","per":"","recovery":""},"consume":{"type":"","target":"","amount":null},"ability":"wis","actionType":"util","attackBonus":"","chatFlavor":"","critical":{"threshold":null,"damage":""},"damage":{"parts":[],"versatile":""},"formula":"","save":{"ability":"","dc":null,"scaling":"wis"},"level":0,"school":"trs","components":{"vocal":true,"somatic":false,"material":false,"ritual":false,"concentration":false},"materials":{"value":"","consumed":false,"cost":0,"supply":0},"preparation":{"mode":"always","prepared":true},"scaling":{"mode":"none","formula":""}},"ownership":{"default":0,"Zs7yJru4DCapi5DP":3,"g4H9tVSZO1YiYQWD":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[{"_id":"2tK1sFzQxtYyRzrz","changes":[{"key":"system.bonuses.abilities.save","mode":2,"value":"+1d4","priority":20},{"key":"system.bonuses.mwak.attack","mode":2,"value":"+1d4","priority":20},{"key":"system.bonuses.msak.attack","mode":2,"value":"+1d4","priority":20},{"key":"system.bonuses.rsak.attack","mode":2,"value":"+1d4","priority":20},{"key":"system.bonuses.rw